{
  "name": "tidy-desktop",
  "version": "1.10.11",
  "description": "桌面整理应用",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json && electron .\"",
    "electron:build": "vite build && tsc -p tsconfig.main.json && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pinyin-pro": "^3.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
