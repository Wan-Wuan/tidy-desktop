{
  "name": "tidy-desktop",
  "version": "2.0.3",
  "description": "桌面整理应用",
  "author": "Wan-Wuan",
  "license": "MIT",
  "repository": "https://github.com/Wan-Wuan/tidy-desktop",
  "homepage": "https://github.com/Wan-Wuan/tidy-desktop",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:main": "node scripts/clean-main-build.mjs && tsc -p tsconfig.main.json",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json && node scripts/wait-for-vite-electron.mjs\"",
    "electron:build": "vite build && npm run build:main && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "pinyin-pro": "^3.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.0",
    "concurrently": "^10.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.0"
  }
}
